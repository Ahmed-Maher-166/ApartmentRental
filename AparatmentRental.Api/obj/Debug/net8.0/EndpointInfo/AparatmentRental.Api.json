                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApartmentDTO"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApartmentDTO"
                }
              }
            }
          }
        }
